// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid()) @map("user_id")
  firstName      String          @map("first_name")
  lastName       String          @map("last_name")
  email          String          @unique
  phoneNumber    String          @unique @map("phone_number")
  // tabs           Tab[]
  paymentMethods PaymentMethod[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("users")
}

model Venue {
  id                  String   @id @default(uuid()) @map("venue_id")
  name                String   @map("venue_name")
  address             String
  latLng              String   @map("lat_lng")
  city                String
  country             String
  authorizationAmount Int      @map("authorization_amount")
  // tabs      Tab[] // One-to-many relationship with user tabs
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("venues")
}

model PaymentMethod {
  id                   String   @id @default(uuid()) @map("payment_method_id")
  userId               String   @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gatewayCustomerToken String   @map("gateway_customer_token")
  gatewayPaymentToken  String   @map("gateway_payment_token")
  providerType         String   @map("provider_type")
  maskedIdentifier     String   @map("masked_identifier")
  isActive             Boolean  @default(true) @map("is_active")
  // tabs                 Tab[]
  tabs                 String[]
  createdAt            DateTime @default(now()) @map("created_at")

  @@map("payment_methods")
}
