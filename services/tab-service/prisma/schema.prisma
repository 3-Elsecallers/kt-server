// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TabStatus {
  OPEN
  ACTIVE
  PENDING_SETTLEMENT
  CLOSED
  ABANDONED
}

model Tab {
  id              String    @id @default(uuid()) @map("tab_id")
  userId          String    @unique @map("user_id")
  venueId         String    @map("venue_id")
  paymentMethodId String    @map("payment_method_id")
  posTabReference String?   @map("pos_tab_reference") // id generated by the bar's physical POS terminal
  status          TabStatus @default(OPEN)
  preAuthAmount   Decimal   @map("pre_auth_amount")
  runningTotal    Decimal   @default(0) @map("running_total")
  openedAt        DateTime  @default(now()) @map("opened_at")
  lastActivityAt  DateTime  @default(now()) @map("last_activity_at")
  closedAt        DateTime? @map("closed_at")
  vatAmount       Decimal?  @map("vat_amount")
  totalPaid       Decimal?  @map("total_paid")
  tabItems        TabItem[]
  transactions    String[]

  @@index([status, venueId], name: "idx_tabs_status_venue")
  @@map("tabs")
}

model TabItem {
  id         String   @id @default(uuid()) @map("item_id")
  tabId      String   @map("tab_id")
  tab        Tab      @relation(fields: [tabId], references: [id], onDelete: Cascade)
  posItemId  String   @map("pos_item_id")
  itemName   String   @map("item_name")
  quantity   Int      @default(1)
  unitPrice  Decimal  @map("unit_price")
  totalPrice Decimal  @map("total_price")
  orderedAt  DateTime @default(now()) @map("ordered_at")

  @@map("tab_items")
}
